<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="50dp"
    android:paddingBottom="3dp">

    <!-- Sélecteur de couleur -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <View
                android:id="@+id/fColVert"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/shape_circle_green" />

            <View
                android:id="@+id/fColRouge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/shape_circle_red" />

            <View
                android:id="@+id/fColBleu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/shape_circle_blue" />

            <View
                android:id="@+id/fColJaune"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/shape_circle_yellow" />

            <View
                android:id="@+id/fColOrange"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/shape_circle_orange" />

            <View
                android:id="@+id/fColGris"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/shape_circle_gray" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Zone de la note, fond coloré avec coins arrondis -->
    <LinearLayout
        android:id="@+id/zoneNote"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/shape_note_card"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:background="@null"
            android:inputType="textCapSentences" />

        <EditText
            android:id="@+id/edtContenu"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:gravity="top"
            android:hint="Contenu"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:background="@null"
            android:inputType="textMultiLine|textCapSentences" />
    </LinearLayout>

    <!-- Bouton Créer / Modifier -->
    <Button
        android:id="@+id/btnEnregistrer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="30dp"

        android:background="@drawable/bg_bouton_enregistrer"
        android:text="Créer"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold" />

</LinearLayout>