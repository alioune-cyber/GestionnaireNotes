<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/rootMain"
    android:background="?android:attr/colorBackground"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="50dp"
    android:paddingBottom="3dp">

    <TextView
        android:id="@+id/txtTitrePage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mes Notes"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.01"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="30dp" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTitrePage"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_recherche"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/edtRecherche"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:hint="Rechercher"
                android:background="@null"
                android:textColor="@color/black"
                android:textColorHint="@color/gris"
                android:singleLine="true" />

        </LinearLayout>

        <Button
            android:id="@+id/btnFavoris"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Favoris"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:background="@drawable/bg_bouton_pilule" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/secondBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtCompteur"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="0 note(s)"
            android:textSize="16sp"
            android:textColor="@color/gris" />

        <Button
            android:id="@+id/btnTri"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Trier"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnModeSombre"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="🌙"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtVide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Aucune notes"
        android:textColor="@color/gris"
        android:textSize="14sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listNotes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/secondBar"
        android:layout_above="@id/btnAjouter"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:divider="@null"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/palette"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_above="@id/btnAjouter"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone">

        <View android:id="@+id/colVert" android:layout_width="36dp" android:layout_height="36dp" android:background="@color/vert" android:layout_margin="4dp" />
        <View android:id="@+id/colRouge" android:layout_width="36dp" android:layout_height="36dp" android:background="@color/rouge" android:layout_margin="4dp" />
        <View android:id="@+id/colBleu" android:layout_width="36dp" android:layout_height="36dp" android:background="@color/bleu" android:layout_margin="4dp" />
        <View android:id="@+id/colJaune" android:layout_width="36dp" android:layout_height="36dp" android:background="@color/jaune" android:layout_margin="4dp" />
        <View android:id="@+id/colOrange" android:layout_width="36dp" android:layout_height="36dp" android:background="@color/orange" android:layout_margin="4dp" />
        <View android:id="@+id/colGris" android:layout_width="36dp" android:layout_height="36dp" android:background="@color/gris" android:layout_margin="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnAjouter"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="8dp"
        android:text="+"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:background="@drawable/bg_bouton_rond" />

</RelativeLayout>